{
  "name": "a1-suppliers-automation-engine",
  "version": "1.0.0",
  "description": "Backend connector for A1 Suppliers: intake -> Airtable + Twilio SMS + Email, with structured logging into Message_Log. Dry-run by default.",
  "type": "commonjs",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/server.js",
    "build": "node -e \"require('./src/server.js')\" --check || true",
    "verify": "node scripts/verify-build.js",
    "test": "node test/endpoints.test.js"
  },
  "engines": {
    "node": ">=18"
  },
  "optionalDependencies": {
    "airtable": "^0.12.2",
    "twilio": "^5.3.0",
    "nodemailer": "^6.9.14"
  },
  "license": "MIT"
}
