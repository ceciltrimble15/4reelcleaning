# A1 Suppliers Automation Engine — environment variables
#
# Copy this file to `.env.local` and fill in real values for local development.
# NEVER commit real secrets. `.env.local` and `.env*` are gitignored.
# In production (Vercel), set these in Project Settings → Environment Variables.

# --- Airtable ---------------------------------------------------------------
# Personal access token (starts with "pat...") scoped to the base.
AIRTABLE_API_KEY=
# Base identifier (starts with "app...").
AIRTABLE_BASE_ID=

# --- Twilio -----------------------------------------------------------------
# Account SID (starts with "AC...").
TWILIO_ACCOUNT_SID=
# Auth token for the account.
TWILIO_AUTH_TOKEN=
# Sending phone number in E.164 format, e.g. +15551234567.
TWILIO_PHONE_NUMBER=

# --- Email ------------------------------------------------------------------
# Email provider identifier, e.g. "resend", "sendgrid", or "smtp".
EMAIL_PROVIDER=
# Default From address, e.g. "no-reply@example.org".
EMAIL_FROM=
