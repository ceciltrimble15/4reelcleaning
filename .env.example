# ---------------------------------------------------------------------------
# A1 Suppliers Automation Engine - environment configuration
# Copy this file to `.env` and fill in real values to go live.
# Until real keys are present, the engine runs in DRY-RUN mode and only logs
# the actions it WOULD perform (no real Airtable writes / SMS / email).
# ---------------------------------------------------------------------------

# --- Server ---------------------------------------------------------------
PORT=3000
NODE_ENV=development

# Master switch. "true" (default) = simulate everything, never call vendors.
# Set to "false" only when real credentials below are populated.
DRY_RUN=true

# Comma-separated CORS allowlist. Defaults to the two approved origins.
CORS_ALLOWED_ORIGINS=https://a1suppliers.org,https://a1-suppliers-website.vercel.app

# --- Airtable -------------------------------------------------------------
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# Table names (defaults match IMPLEMENTATION_PROMPT.md; override only if needed)
AIRTABLE_TABLE_CONTACTS=A1_Suppliers_Contacts
AIRTABLE_TABLE_YOUTH=Youth_Intake
AIRTABLE_TABLE_PARENT_GUARDIAN=Parent_Guardian_Intake
AIRTABLE_TABLE_MENTOR=Mentor_Intake
AIRTABLE_TABLE_VOLUNTEER=Volunteer_Intake
AIRTABLE_TABLE_PARTNER_DONOR=Partner_Donor_Intake
AIRTABLE_TABLE_MESSAGE_LOG=Message_Log

# --- Twilio (SMS) ---------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Where internal notification SMS are sent (staff/admin number)
TWILIO_NOTIFY_NUMBER=

# --- Email ----------------------------------------------------------------
# SMTP transport used by the email service when live.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="A1 Suppliers <no-reply@a1suppliers.org>"
# Where internal notification emails are sent (staff/admin inbox)
EMAIL_NOTIFY_TO=info@a1suppliers.org
