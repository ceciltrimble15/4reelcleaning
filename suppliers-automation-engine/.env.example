# Suppliers Automation Engine — environment variables
#
# Copy this file to `.env.local` and fill in real values. All integrations are
# placeholders in Phase 1; the API routes work without these set, but report
# `configured: false` until they are provided.

# --- Airtable ---------------------------------------------------------------
# Personal access token / API key with data.records:write scope.
AIRTABLE_API_KEY=
# The base that holds the intake tables (e.g. appXXXXXXXXXXXXXX).
AIRTABLE_BASE_ID=

# --- Twilio (SMS) -----------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# The Twilio phone number messages are sent from, in E.164 format (+15551234567).
TWILIO_FROM_NUMBER=

# --- Email ------------------------------------------------------------------
# API key for your transactional email provider.
EMAIL_API_KEY=
# Verified sender address.
EMAIL_FROM_ADDRESS=
